# ─── Application ──────────────────────────────────────────────
APP_NAME=BolOrder Voice AI Service
APP_ENV=development
DEBUG=False
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ─── LLM (Gemini) ─────────────────────────────────────────────
# Get your API key from: https://aistudio.google.com/app/apikey
MODEL_PROVIDER=gemini
MODEL_NAME=gemini-1.5-flash
API_KEY=your_gemini_api_key_here

# ─── Whisper (Speech-to-Text) ─────────────────────────────────
# Model sizes (larger = more accurate, slower):
#   tiny | base | small | medium | large
# For development: small is the best balance
WHISPER_MODEL=small
DEVICE=cpu
COMPUTE_TYPE=int8

# ─── MS1 Connection ───────────────────────────────────────────
# The URL of your running Express.js backend
MS1_BASE_URL=http://localhost:3000
MS1_TIMEOUT_SECONDS=10

# ─── TTS ──────────────────────────────────────────────────────
TTS_PROVIDER=gtts

# ─── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Session ──────────────────────────────────────────────────
SESSION_TTL_SECONDS=1800

# ─── Confidence Thresholds ────────────────────────────────────
SHOP_CONFIDENCE_THRESHOLD=70
PRODUCT_CONFIDENCE_THRESHOLD=65
